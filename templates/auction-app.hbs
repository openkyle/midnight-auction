<form class="midnight-auction {{#if isGM}}is-gm{{else}}is-player{{/if}}">
  <section class="ma-auction-board">
    <article class="ma-hero-card">
      <img class="ma-scene" src="{{sceneImage}}" alt="Auction scene">
      <div class="ma-stage-shade">
        <h1>{{title}}</h1>
        <p>{{subtitle}}</p>
      </div>
    </article>

    <article class="ma-bids-card">
      <h3>Latest Bids</h3>
      {{#if bids.length}}
      <ol>
        {{#each bids}}
        <li>{{summary}}</li>
        {{/each}}
      </ol>
      {{else}}
      <p>No bids yet.</p>
      {{/if}}
    </article>
  </section>

  <section class="ma-lot-board">
    <div class="ma-item-image-wrap">
      <img class="ma-item-image" src="{{item.img}}" alt="{{item.name}}">
    </div>
    <div class="ma-item-detail">
      <div class="ma-eyebrow">Current Lot</div>
      <h2>{{item.name}}</h2>
      <div class="ma-description">{{{itemDescription}}}</div>
    </div>
    <div class="ma-highest-card">
      <span>Highest Bidder</span>
      <div class="ma-bidder-avatar" style="background: {{highestBidder.avatarStyle}}">{{highestBidder.initial}}</div>
      <strong>{{highestBidder.name}}</strong>
    </div>
    <div class="ma-price">
      <span>Current Price</span>
      <strong>{{currentPrice}} gp</strong>
      <small>Next bid: {{nextBid}} gp</small>
    </div>
  </section>

  <section class="ma-action-row">
    <div class="ma-wallet">
      <span>Your Gold</span>
      <strong>{{gold}} gp</strong>
    </div>
    <button class="ma-bid" type="button" data-action="bid" {{#unless canBid}}disabled{{/unless}}>
      <span class="ma-bid-progress" style="width: {{timerProgress}}%"></span>
      <strong>Bid {{nextBid}} gp</strong>
    </button>
    <div class="ma-timer {{#if urgent}}is-urgent{{/if}}">
      <span>{{timerLabel}}</span>
      <strong>{{timeDisplay}}</strong>
    </div>
  </section>

  {{#if isGM}}
  <section class="ma-gm-controls">
    <div class="ma-toolbar">
      <button type="button" data-action="toggle-settings" title="Auction settings"><i class="fas fa-cog"></i></button>
      <button type="button" data-action="npc-bid" {{#unless canNpcBid}}disabled{{/unless}}><i class="fas fa-user-secret"></i> NPC Bid {{nextNpcBid}} gp</button>
      <button type="button" data-action="refresh"><i class="fas fa-sync"></i> Refresh</button>
      <button type="button" data-action="stop-auction"><i class="fas fa-stop"></i> End Auction</button>
    </div>

    {{#if showSettings}}
    <section class="ma-settings-panel">
      <label>Bid Timer
        <select data-setting="timerMode">
          {{#each settings.timerOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>Sudden Death
        <input type="number" min="1" value="{{settings.suddenDeathSeconds}}" data-setting="suddenDeathSeconds">
      </label>
      <label>Start %
        <input type="number" min="0" value="{{settings.startingBidPercent}}" data-setting="startingBidPercent">
      </label>
      <label>Rounds
        <input type="number" min="1" max="10" value="{{settings.roundCount}}" data-setting="roundCount">
      </label>
      <label>Bid Step
        <input type="number" min="1" value="{{settings.defaultIncrement}}" data-setting="defaultIncrement">
      </label>
      <label>NPC Step
        <input type="number" min="1" value="{{settings.npcBidIncrement}}" data-setting="npcBidIncrement">
      </label>
    </section>
    {{/if}}

    <section class="ma-npc-panel" data-npc-drop>
      <div class="ma-panel-title">Drop Auction Bidders here</div>
      <div class="ma-npc-list">
        {{#each npcBidders}}
        <div class="ma-npc-row" data-npc-index="{{@index}}">
          <span>{{number}}</span>
          <input type="text" value="{{name}}" data-npc-field="name" data-npc-index="{{@index}}">
        </div>
        {{/each}}
      </div>
    </section>

    <nav class="ma-round-tabs" aria-label="Auction rounds">
      {{#each rounds}}
      <button type="button" class="{{#if selected}}is-selected{{/if}} {{#if active}}is-live{{/if}}" data-action="select-round" data-round-id="{{id}}">
        {{title}}
      </button>
      {{/each}}
    </nav>

    {{#if selectedRound}}
    <article class="ma-round {{#if selectedRound.active}}is-active{{/if}}">
      <header>
        <div class="ma-round-actions">
          <button type="button" data-action="start-round" data-round-id="{{selectedRound.id}}">Start Round</button>
          <button type="button" data-action="end-round" data-round-id="{{selectedRound.id}}">End Round</button>
        </div>
        <div class="ma-drop-zone" data-round-drop="{{selectedRound.id}}">
          <div class="ma-panel-title">Drop auction items here</div>
          <div class="ma-drop-list">
            {{#each selectedRound.items}}
            <div class="ma-drop-row {{#if active}}is-active{{/if}} {{#if complete}}is-complete{{/if}}">
              <span>{{name}}</span>
              <button type="button" data-action="start-item" data-item-id="{{id}}">Start</button>
              <button type="button" data-action="end-item" data-item-id="{{id}}">End</button>
              <button class="ma-delete-item" type="button" data-action="delete-item" data-item-id="{{id}}" title="Remove lot">X</button>
            </div>
            {{else}}
            <p class="ma-empty">No lots yet.</p>
            {{/each}}
          </div>
        </div>
      </header>
    </article>
    {{/if}}
  </section>
  {{/if}}
</form>
