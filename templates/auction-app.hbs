<form class="midnight-auction {{#if isGM}}is-gm{{else}}is-player{{/if}}">
  <section class="ma-stage">
    <img class="ma-scene" src="{{sceneImage}}" alt="Auction scene">
    <div class="ma-stage-shade">
      <div>
        <h1>{{title}}</h1>
        <p>{{subtitle}}</p>
      </div>
      <div class="ma-timer {{#if urgent}}is-urgent{{/if}}">
        <span>{{timerLabel}}</span>
        <strong>{{timeLeft}}</strong>
      </div>
    </div>
  </section>

  <section class="ma-current">
    <div class="ma-item-image-wrap">
      <img class="ma-item-image" src="{{item.img}}" alt="{{item.name}}">
    </div>
    <div class="ma-item-detail">
      <div class="ma-eyebrow">Current Lot</div>
      <h2>{{item.name}}</h2>
      <div class="ma-description">{{{itemDescription}}}</div>
    </div>
    <div class="ma-price">
      <span>Current Price</span>
      <strong>{{currentPrice}} gp</strong>
      <small>Next bid: {{nextBid}} gp</small>
    </div>
  </section>

  {{#if isGM}}
  <section class="ma-gm-controls">
    <div class="ma-toolbar">
      <button type="button" data-action="add-round"><i class="fas fa-plus"></i> Add Round</button>
      <button type="button" data-action="refresh"><i class="fas fa-sync"></i> Refresh</button>
      <button type="button" data-action="stop-auction"><i class="fas fa-stop"></i> End Auction</button>
    </div>

    {{#each rounds}}
    <article class="ma-round {{#if active}}is-active{{/if}}">
      <header>
        <div class="ma-round-title">
          <label>No. <input type="number" min="1" value="{{number}}" data-field="number" data-round-id="{{id}}"></label>
          <label>Round <input type="text" value="{{title}}" data-field="title" data-round-id="{{id}}"></label>
        </div>
        <div class="ma-round-actions">
          <button type="button" data-action="start-round" data-round-id="{{id}}">Start Round</button>
          <button type="button" data-action="end-round" data-round-id="{{id}}">End Round</button>
          <button type="button" data-action="add-item" data-round-id="{{id}}">Add Lot</button>
          <button type="button" data-action="delete-round" data-round-id="{{id}}">Delete</button>
        </div>
      </header>

      <div class="ma-lots">
        {{#each items}}
        <div class="ma-lot {{#if active}}is-active{{/if}}">
          <img src="{{img}}" alt="{{name}}">
          <div class="ma-lot-main">
            <div class="ma-lot-fields ma-lot-fields-wide">
              <label>Name <input type="text" value="{{name}}" data-field="name" data-item-id="{{id}}"></label>
              <label>Item Image <input type="text" value="{{img}}" data-field="img" data-item-id="{{id}}"></label>
              <label>Scene Image <input type="text" value="{{sceneImg}}" data-field="sceneImg" data-item-id="{{id}}"></label>
              <label>Start <input type="number" min="0" value="{{startingPrice}}" data-field="startingPrice" data-item-id="{{id}}"></label>
              <label>Increment <input type="number" min="1" value="{{increment}}" data-field="increment" data-item-id="{{id}}"></label>
            </div>
            <label class="ma-description-field">Description
              <textarea data-field="description" data-item-id="{{id}}">{{description}}</textarea>
            </label>
          </div>
          <div class="ma-lot-actions">
            <button type="button" data-action="start-item" data-item-id="{{id}}">Start</button>
            <button type="button" data-action="end-item" data-item-id="{{id}}">End</button>
            <button type="button" data-action="delete-item" data-item-id="{{id}}">Delete</button>
          </div>
        </div>
        {{else}}
        <p class="ma-empty">No lots in this round yet.</p>
        {{/each}}
      </div>
    </article>
    {{/each}}
  </section>
  {{else}}
  <section class="ma-player-controls">
    <div class="ma-wallet">
      <span>Your Gold</span>
      <strong>{{gold}} gp</strong>
    </div>
    <button class="ma-bid" type="button" data-action="bid" {{#unless canBid}}disabled{{/unless}}>
      Bid {{nextBid}} gp
    </button>
  </section>
  {{/if}}

  <section class="ma-log">
    <h3>Latest Bids</h3>
    {{#if bids.length}}
    <ol>
      {{#each bids}}
      <li>
        <strong>{{bidderName}}</strong>
        <span>{{amount}} gp</span>
      </li>
      {{/each}}
    </ol>
    {{else}}
    <p>No bids yet.</p>
    {{/if}}
  </section>
</form>
